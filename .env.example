# 4Pie Labs - environment variable template.
# Copy this file to .env.local and fill in real values. .env.local is gitignored.
# Vercel project settings must also have these set for the deployed site.

# -- Anthropic (chatbot) -----------------------------------------------------
# API key from https://console.anthropic.com. Required for /api/chat to return
# a reply. Without it, the chat route returns 500.
ANTHROPIC_API_KEY=

# -- Supabase ----------------------------------------------------------------
# Project URL (e.g. https://abcdefgh.supabase.co). Required - the chat route,
# every lead form, and the admin portal all read or write through it.
NEXT_PUBLIC_SUPABASE_URL=

# Anon (publishable) key. Required for the cookie-free public client used by
# anon reads, chat conversation upserts, and form lead inserts.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key. Required for the admin portal (bypasses RLS to read leads,
# conversations, publish blogs/testimonials). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# -- Admin portal auth -------------------------------------------------------
# Email + password for the single admin user. Checked via timing-safe compare
# in /admin/login. Not a Supabase Auth user.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# HMAC secret for signing the admin session cookie. Must be >= 32 chars.
# Generate with `openssl rand -base64 48` or similar.
ADMIN_SESSION_SECRET=

# -- Cal.com booking (/book) -------------------------------------------------
# Personal API key from cal.com/settings/developer/api-keys. Required for the
# /book page to fetch slots and create bookings.
CAL_API_KEY=

# Numeric event-type id (cal.com/event-types/<id>). Required for booking.
CAL_EVENT_TYPE_ID=

# -- Resend transactional email ----------------------------------------------
# API key from https://resend.com/api-keys. Used by /lib/email.ts to send
# lead alerts to the team and confirmations to the customer. Optional - if
# unset, lead capture still works; email is best-effort and never blocks the
# form flow.
RESEND_API_KEY=

# Sender identity. Must match a domain verified in Resend
# (https://resend.com/domains). Format: "Display Name <address@domain>".
EMAIL_FROM=4Pie Labs <noreply@mail.fourpielabs.com>

# Reply-To header. Set to the inbox a customer's reply should land in.
EMAIL_REPLY_TO=team@fourpielabs.com

# Internal address that receives the "new lead" alert email.
LEAD_ALERT_TO=team@fourpielabs.com

# -- n8n audit webhook -------------------------------------------------------
# Webhook the /audit form POSTs to after a successful lead capture. Not a secret. n8n receives { Website, email, name, businessName, source } and generates + emails the report.
N8N_AUDIT_WEBHOOK_URL=https://n8n.treathealth.ai/webhook/ai-trust-audit-ghl
